# 明烛敏感信息配置（不入版本控制）
# 复制此文件为 .env，填入真实信息
# .env 已在 .gitignore 中，不会上传 GitHub

# === 个人档案敏感信息（请替换为真实值，切勿在 example 中填入真实数据）===
MZ_BIRTH_DATE="YYYY-MM-DD HH:MM"
MZ_BIRTH_PLACE="出生城市"
MZ_SUN_SIGN="星座 度数"
MZ_MOON_SIGN="星座 度数"
MZ_ASCENDANT="星座 度数"

# === LLM API Keys ===
ZHIPU_API_KEY=""
DEEPSEEK_API_KEY=""

# === LangSmith Tracing（可观测性）===
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="mingzhu"
